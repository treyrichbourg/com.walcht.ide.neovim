<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement name="root" enabled="true" style="flex-grow: 1; flex-direction: row; width: 100%; height: 100%; align-items: stretch; justify-content: flex-start; align-self: auto; align-content: flex-start; flex-shrink: 1; -unity-text-generator: standard;">
        <ui:VisualElement name="left-panel" style="flex-grow: 1; padding-left: 5px; padding-right: 5px; padding-top: 5px; padding-bottom: 5px; justify-content: flex-start; height: 100%; align-items: stretch; width: 70%;">
            <ui:Label text="Neovim Settings" name="neovim-settings" style="-unity-font-style: bold; padding-top: 5px; padding-right: 5px; padding-bottom: 5px; padding-left: 5px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0;"/>
            <ui:ScrollView name="main-area" enabled="true" mode="Vertical" style="flex-grow: 1; height: auto; opacity: 1; display: flex; flex-shrink: 1;">
                <ui:VisualElement name="project-generation-settings" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); padding-bottom: 5px; margin-bottom: 5px; padding-left: 5px; border-top-width: 1px; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; padding-top: 5px; padding-right: 5px;">
                    <ui:Label text="Generate .csproj files for:" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal;"/>
                    <ui:VisualElement style="flex-grow: 1; flex-direction: column; flex-wrap: wrap; align-items: stretch; justify-content: flex-start; align-self: auto; align-content: flex-start;">
                        <ui:VisualElement name="built-in-packages" style="flex-grow: 1; flex-direction: row; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; background-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px;">
                            <ui:Label text="built-in packages" tooltip="Generate .csproj files for referenced built-in packages. This adds LSP support for referenced built-in packages." style="flex-grow: 1; flex-shrink: 1; -unity-text-align: middle-left;"/>
                            <ui:Toggle label="" name="built-in-packages-tg"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="registry-packages" style="flex-grow: 1; flex-direction: row; border-top-left-radius: 0; border-top-right-radius: 0; border-bottom-right-radius: 0; border-bottom-left-radius: 0; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px;">
                            <ui:Label text="registry packages" tooltip="Generate .csproj files for packages installed from the Unity Registry. This adds LSP support for Unity Registry packages." style="flex-grow: 1; flex-shrink: 1; -unity-text-align: middle-left;"/>
                            <ui:Toggle label="" name="registry-packages-tg"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="git-packages" style="flex-grow: 1; flex-direction: row; background-color: rgb(77, 77, 77); padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px;">
                            <ui:Label text="git packages" tooltip="Generate .csproj files for packages installed from Git. This adds LSP support for Git packages." style="flex-grow: 1; flex-shrink: 1; -unity-text-align: middle-left;"/>
                            <ui:Toggle label="" name="git-packages-tg"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="local-packages" style="flex-grow: 1; flex-direction: row; background-color: rgba(0, 0, 0, 0); margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px;">
                            <ui:Label text="local packages" tooltip="Generate .csproj files for packages installed locally from disk. This adds LSP support for local/disk packages." style="flex-grow: 1; flex-shrink: 1; -unity-text-align: middle-left;"/>
                            <ui:Toggle label="" name="local-packages-tg" style="flex-direction: row; align-self: center; align-content: flex-start; align-items: stretch;"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="local-tarball-packages" style="flex-grow: 1; flex-direction: row; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; background-color: rgb(77, 77, 77);">
                            <ui:Label text="local tarball packages" tooltip="Generate .csproj files for referenced local tarball packages. This adds LSP support for referenced local tarball-installed packages." style="flex-grow: 1; flex-shrink: 1; -unity-text-align: middle-left;"/>
                            <ui:Toggle label="" name="local-tarball-packages-tg"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="embedded-packages" style="flex-grow: 1; flex-direction: row; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; background-color: rgba(0, 0, 0, 0);">
                            <ui:Label text="embedded packages" style="flex-grow: 1; flex-shrink: 1; -unity-text-align: middle-left;"/>
                            <ui:Toggle label="" name="embedded-packages-tg"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="unknown-source-packages" style="flex-grow: 1; flex-direction: row; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; background-color: rgb(77, 77, 77);">
                            <ui:Label text="unknown-source packages" tooltip="Generate .csproj files for referenced unknown packages. This adds LSP support for referenced unknown packages." style="flex-grow: 1; flex-shrink: 1; border-bottom-left-radius: 5px; border-bottom-right-radius: 5px; -unity-text-align: middle-left;"/>
                            <ui:Toggle label="" name="unknown-source-packages-tg"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="nvim-executable-path" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); padding-bottom: 5px; margin-bottom: 5px; padding-left: 5px; border-top-width: 1px; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; padding-top: 5px; padding-right: 5px;">
                    <ui:Label text="Change Neovim executable path:" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal;"/>
                    <ui:TextField label="nvim path:" placeholder-text="path/to/nvim.exe" name="nvim-exec-path-tf" tooltip="Currently set nvim absolute executable path. Change this if, for some reason, you encounter issues with Neovim discovery (in External Editor Settings)."/>
                </ui:VisualElement>
                <ui:VisualElement name="terminal-launch-cmd-args" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-bottom-color: rgb(77, 77, 77); padding-left: 5px; padding-bottom: 5px; border-top-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; padding-top: 5px; padding-right: 5px; margin-bottom: 5px;">
                    <ui:Label text="Configure terminal launch command to create the initial Neovim server instance:" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal;"/>
                    <ui:TextField label="command:" placeholder-text="filler text" tooltip="Executable that will be executed whenever you request to open a file for the first time. This has to be accessible (i.e., added in your PATH)." name="terminal-launch-cmd-tf"/>
                    <ui:TextField label="arguments:" placeholder-text="filler text" name="terminal-launch-args-tf" tooltip="Arguments to be passed to the executable above. Text between {} is for special placeholders." vertical-scroller-visibility="Hidden" multiline="false" style="white-space: nowrap; flex-grow: 1;"/>
                    <ui:TextField label="environments:" placeholder-text="ENV_0=VALUE_0 ENV_1=VALUE_1 ENV_N=VALUE_N" tooltip="A set of environment variables to be passed to this terminal launch process. In the form of a space separated list: ENV_0=VALUE_0 ENV_1=VALUE_1 ... ENV_N=VALUE_N" name="terminal-launch-env-tf"/>
                </ui:VisualElement>
                <ui:VisualElement name="jump-to-cursor-pos-args" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; padding-left: 5px; padding-bottom: 5px; border-bottom-color: rgb(77, 77, 77); border-bottom-width: 1px; padding-top: 5px; padding-right: 5px; margin-bottom: 5px; border-top-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="Configure how Neovim jumps to requested cursor position:" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal;"/>
                    <ui:TextField label="arguments:" placeholder-text="filler text" name="jump-to-cursor-pos-args-tf" tooltip="Arguments to be passed to NeoVim when a cursor position jump to particular file is requested. Text between {} if for special placeholders (read below)."/>
                </ui:VisualElement>
                <ui:VisualElement name="process-timeout" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; padding-top: 5px; padding-right: 5px; padding-bottom: 5px; padding-left: 5px; margin-bottom: 5px; margin-top: 0; border-top-width: 1px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="Change maximum timeout to wait for processes before killing them:" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal;"/>
                    <uie:IntegerField label="process timeout:" value="150" name="process-timeout-if" max-length="4" tooltip="Process timeout is the maximum time in milliseconds to wait for the spawned process to finish. If the process does not finish within this timeout, it will be killed. This timeout is used when spawning the open-file request process, the jumo-to-cursor-position request process, and the focus-on-neovim process. Smaller values result in smoother experience at the cost of a potential process being killed before it finishes its execution."/>
                </ui:VisualElement>
                <ui:VisualElement name="open-file-request-args" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; border-top-width: 1px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); padding-top: 5px; padding-right: 5px; padding-bottom: 5px; padding-left: 5px; margin-top: 0; margin-bottom: 5px; margin-left: 0; margin-right: 0; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="Configure how Neovim opens files when clicked in Unity, per modifier key:" name="Label" enable-rich-text="true" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-left-color: rgb(102, 102, 102); border-right-color: rgb(102, 102, 102); border-top-color: rgb(102, 102, 102); border-bottom-color: rgb(102, 102, 102);"/>
                    <ui:VisualElement name="modifier-binding-rows" style="flex-grow: 1;"/>
                </ui:VisualElement>
                <ui:VisualElement name="analyzers" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; padding-top: 5px; padding-right: 5px; padding-bottom: 5px; padding-left: 5px; margin-bottom: 5px; margin-top: 0; border-top-width: 1px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="Add/Remove C# analyzers:" enable-rich-text="false" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal;"/>
                    <ui:VisualElement name="add-analyzer" style="flex-grow: 1; flex-direction: row;">
                        <ui:TextField label="analyzer path:" placeholder-text="path/to/analyzer.dll" name="analyzer-path-tf" value="" style="flex-grow: 1; flex-shrink: 1; padding-bottom: 5px; -unity-font-style: normal;"/>
                        <ui:Button text="add" name="add-analyzer-btn" style="flex-grow: 0; flex-shrink: 0; align-items: stretch;"/>
                        <ui:Button text="browse" name="browse-analyzer-btn" style="flex-grow: 0; flex-shrink: 0; align-items: stretch;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="analyzer-rows-parent" style="flex-grow: 1; display: flex;">
                        <ui:Label text="current in-use analyzers:" style="padding-left: 3px;"/>
                        <ui:VisualElement name="analyzer-rows" style="flex-grow: 1;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="roslyn-ls-settings" style="flex-grow: 1; border-left-width: 1px; border-right-width: 1px; padding-top: 5px; padding-right: 5px; padding-bottom: 5px; padding-left: 5px; margin-bottom: 5px; margin-top: 0; border-top-width: 1px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="Configure Roslyn Language Server settings:" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 5px; padding-left: 0; white-space: normal;"/>
                    <uie:EnumField label="analyzer_diagnostic_scope" name="analyzer-diagnostic-scope-ef" choices="none,openFiles,fullSolution" index="1" tooltip="Analyzers diagnostics scope for Roslyn LS. For very large projects, setting this to &quot;fullSolution&quot; may degrade the LS performance&#39;s significantly."/>
                    <uie:EnumField label="compiler_diagnostic_scope" name="compiler-diagnostic-scope-ef" choices="none,openFiles,fullSolution" index="1" tooltip="Compiler diagnostics scope for Roslyn LS. For very large projects, setting this to &quot;fullSolution&quot; may degrade the LS performance&#39;s significantly."/>
                </ui:VisualElement>
            </ui:ScrollView>
            <ui:VisualElement name="toolbar" style="flex-grow: 0; flex-direction: row; flex-shrink: 0; align-self: auto; align-content: flex-start; align-items: stretch; position: relative; height: auto; width: auto; top: auto; left: auto; justify-content: flex-start; bottom: auto; right: auto; padding-top: 3px; padding-right: 3px; padding-bottom: 3px; padding-left: 3px;">
                <ui:Button text="Apply" name="apply" style="margin-right: 3px;"/>
                <ui:Button text="[+] Add binding" name="add-binding"/>
                <ui:VisualElement name="spacing" style="flex-grow: 1;"/>
                <ui:Button text="Regenerate project files" name="regenerate-project-files-btn" tooltip="Regenerates all .csproj files according to currently set setting (e.g., analyzers, selected packages, etc.). This regenerates the project files even if their regeneration is not necessary (i.e., force regenerates)."/>
                <ui:Button text="Reset" name="reset" style="margin-left: 25px;"/>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="info-panel" style="flex-grow: 0; width: 30%; flex-shrink: 0; border-left-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); padding-left: 5px; padding-right: 5px; padding-top: 0; padding-bottom: 0; margin-top: 5px; margin-bottom: 5px; margin-right: 0; height: 100%; position: relative; flex-direction: column; justify-content: space-between;">
            <ui:Label text="Template Info" name="template-info" style="-unity-font-style: bold; padding-top: 5px; padding-right: 5px; padding-bottom: 5px; padding-left: 5px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0;"/>
            <ui:VisualElement name="current-template-desc" style="flex-grow: 0; flex-shrink: 0; padding-left: 5px; padding-top: 5px; padding-right: 5px; padding-bottom: 5px; border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                <ui:Label text="Current template:" name="curr-template-name"/>
                <ui:Label text="Select template to show description" name="curr-template-desc" style="padding-left: 10px; font-size: 12px; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; white-space: normal;"/>
            </ui:VisualElement>
            <ui:Label text="Placeholders" style="-unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 5px; padding-right: 5px; padding-bottom: 5px; padding-left: 5px;"/>
            <ui:ScrollView name="placeholders" style="flex-grow: 1; height: 100%;">
                <ui:VisualElement name="app-placeholder" style="flex-grow: 0; margin-top: 0; margin-right: 0; margin-bottom: 5px; margin-left: 0; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; border-top-width: 1px; border-right-width: 1px; border-left-width: 1px; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="&lt;b&gt;{app}&lt;/b&gt; &#8212; current discovered/supplied Neovim path." name="placeholder-name" style="flex-wrap: nowrap; white-space: normal; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                    <ui:TextField label="current value:" placeholder-text="" name="app-placeholder-tf" readonly="true" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 5px; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                </ui:VisualElement>
                <ui:VisualElement name="processpid-placeholder" style="flex-grow: 0; margin-top: 0; margin-right: 0; margin-bottom: 5px; margin-left: 0; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-width: 1px; border-right-width: 1px; border-left-width: 1px; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="&lt;b&gt;{getProcessPPIDScriptPath}&lt;/b&gt; &#8212; path to the GetProcessPPID.ps1 Powershell script which is used to determine the parent process ID which is then used for auto window focusing." name="placeholder-name" style="flex-wrap: nowrap; white-space: normal; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                    <ui:TextField label="current value:" placeholder-text="" name="processpid-placeholder-tf" readonly="true" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 5px; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                </ui:VisualElement>
                <ui:VisualElement name="serversocket-placeholder" style="flex-grow: 0; margin-top: 0; margin-right: 0; margin-bottom: 5px; margin-left: 0; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-width: 1px; border-right-width: 1px; border-left-width: 1px; border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px;">
                    <ui:Label text="&lt;b&gt;{serverSocket}&lt;/b&gt; &#8212; TCP communication socket with the Neovim server instance." name="placeholder-name" style="flex-wrap: nowrap; white-space: normal; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                    <ui:TextField label="current value:" placeholder-text="" name="serversocket-placeholder-tf" readonly="true" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 5px; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                </ui:VisualElement>
                <ui:VisualElement name="instanceid-placeholder" style="flex-grow: 0; margin-top: 0; margin-right: 0; margin-bottom: 5px; margin-left: 0; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; border-top-width: 1px; border-right-width: 1px; border-left-width: 1px;">
                    <ui:Label text="&lt;b&gt;{instanceId}&lt;/b&gt; &#8212; unique identifier for this Unity instance (PID)." name="placeholder-name" style="flex-wrap: nowrap; white-space: normal; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                    <ui:TextField label="current value:" placeholder-text="" name="instanceid-placeholder-tf" readonly="true" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 5px; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                </ui:VisualElement>
                <ui:VisualElement name="project-root-dir-placeholder" style="flex-grow: 0; margin-top: 0; margin-right: 0; margin-bottom: 5px; margin-left: 0; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; border-bottom-width: 1px; border-left-color: rgb(77, 77, 77); border-right-color: rgb(77, 77, 77); border-top-color: rgb(77, 77, 77); border-bottom-color: rgb(77, 77, 77); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; border-top-width: 1px; border-right-width: 1px; border-left-width: 1px;">
                    <ui:Label text="&lt;b&gt;{projectRootDir}&lt;/b&gt; &#8212; current Unity project root dir which contains the folders: Assets, Library, etc." name="project-root-dir-placeholder-tf" style="flex-wrap: nowrap; white-space: normal; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
